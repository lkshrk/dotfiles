#!/usr/bin/env bash

set -euo pipefail

source_dir="${CODER_DOTFILES_SOURCE_DIR:-$HOME/dotfiles}"
runtime_dir="${CODER_DOTFILES_RUNTIME_DIR:-$HOME/.local/share/dotfiles-runtime}"
capture_all=0
include_untracked=0
paths=()

usage() {
  cat <<'EOF'
Usage:
  capture-coder-dotfiles
  capture-coder-dotfiles [--include-untracked] PATH...
  capture-coder-dotfiles --all

With no arguments, list runtime changes. Explicit paths capture tracked changes
into ~/dotfiles. Use --include-untracked only with explicit paths.
EOF
}

die() {
  printf 'capture-coder-dotfiles: %s\n' "$*" >&2
  exit 1
}

while (($#)); do
  case "$1" in
    --all) capture_all=1 ;;
    --include-untracked) include_untracked=1 ;;
    -h|--help) usage; exit 0 ;;
    --) shift; paths+=("$@"); break ;;
    -*) die "unknown option: $1" ;;
    *) paths+=("$1") ;;
  esac
  shift
done

[[ -d "$source_dir/.git" ]] || die "source checkout not found: $source_dir"
[[ -d "$runtime_dir/.git" ]] || die "runtime checkout not found: $runtime_dir"
[[ "$(cd "$source_dir" && pwd -P)" != "$(cd "$runtime_dir" && pwd -P)" ]] \
  || die "source and runtime directories must differ"

if ((capture_all && ${#paths[@]})); then
  die "use --all or explicit paths, not both"
fi
if ((include_untracked && ! ${#paths[@]})); then
  die "--include-untracked requires explicit paths"
fi

if ((!capture_all && ! ${#paths[@]})); then
  git -C "$runtime_dir" status --short
  exit 0
fi

tmp_dir="$(mktemp -d)"
trap 'rm -rf "$tmp_dir"' EXIT
patch_file="$tmp_dir/tracked.patch"
untracked_file="$tmp_dir/untracked"

if ((capture_all)); then
  git -C "$runtime_dir" diff --binary --full-index HEAD >"$patch_file"
else
  git -C "$runtime_dir" diff --binary --full-index HEAD -- "${paths[@]}" \
    >"$patch_file"
fi

: >"$untracked_file"
if ((include_untracked)); then
  git -C "$runtime_dir" ls-files -z --others --exclude-standard -- \
    "${paths[@]}" >"$untracked_file"

  while IFS= read -r -d '' file; do
    [[ ! -e "$source_dir/$file" && ! -L "$source_dir/$file" ]] \
      || die "source path already exists: $file"
  done <"$untracked_file"
fi

if [[ -s "$patch_file" ]] && \
  ! git -C "$source_dir" apply --3way --check "$patch_file" >/dev/null 2>&1; then
  die "tracked changes conflict with the source checkout"
fi

captured=0
if [[ -s "$patch_file" ]]; then
  git -C "$source_dir" apply --3way "$patch_file"
  captured=1
fi

while IFS= read -r -d '' file; do
  mkdir -p "$(dirname "$source_dir/$file")"
  cp -pP "$runtime_dir/$file" "$source_dir/$file"
  captured=1
done <"$untracked_file"

if ((!captured)); then
  printf 'Nothing to capture. Untracked files require --include-untracked.\n'
  exit 0
fi

printf 'Captured into %s; runtime checkout unchanged.\n' "$source_dir"
if ((capture_all)); then
  git -C "$source_dir" status --short
else
  git -C "$source_dir" status --short -- "${paths[@]}"
fi
