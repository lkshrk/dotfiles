# claude — only settings.json and plugins/installed_plugins.json are tracked.
# Everything else under ~/.claude is runtime/state and ignored:
claude/.claude/*
!claude/.claude/settings.json
!claude/.claude/statusline-command.sh
!claude/.claude/plugins/
claude/.claude/plugins/*
!claude/.claude/plugins/installed_plugins.json
