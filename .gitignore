# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# AI assistant project-local settings/state (not stowed packages under dotfiles/)
/.agents/
/.claude/
/.codex/
/.codegraphcontext/
/.continue/
/.cursor/
/.crush/
/.gemini/
/.goose/
/.leankg/
/.mcp/
/.qwen/
/.roo/
/.serena/
/.windsurf/
/.aider*
/AGENTS.local.md
/CLAUDE.local.md
/GEMINI.local.md
.omc/

# zsh runtime
dotfiles/zsh/.config/zsh/.zcompdump*
dotfiles/zsh/.config/zsh/.zsh_history

# nvim vendored/runtime files
dotfiles/nvim/.config/nvim/lazy-lock.json
dotfiles/nvim/.config/nvim/LICENSE.md
dotfiles/nvim/.config/nvim/README.md

# opencode runtime backups
dotfiles/opencode/.config/opencode/*.backup-*
dotfiles/opencode/.config/opencode/*.bak.*

# omni runtime backups
dotfiles/omni/.config/omni/*.bak*

# intentionally unmanaged ~/.config trees
dotfiles/acli/.config/acli/
dotfiles/cagent/.config/cagent/
dotfiles/configstore/.config/configstore/
dotfiles/github-copilot/.config/github-copilot/
dotfiles/karabiner/.config/karabiner/
dotfiles/llmctl/.config/llmctl/
dotfiles/mole/.config/mole/
dotfiles/moshi/.config/moshi/
dotfiles/talos/.config/talos/
dotfiles/ttllm/.config/ttllm/
dotfiles/com.corsair/.config/com.corsair/

# ignored discovery candidates
acli/
cagent/
configstore/
github-copilot/
karabiner/
llmctl/
mole/
moshi/
talos/
ttllm/
com.corsair/

# local credentials/state
dotfiles/git/.config/git/config.local
dotfiles/gh/.config/gh/hosts.yml
dotfiles/zed/.config/zed/conversations/
dotfiles/zed/.config/zed/prompts/
dotfiles/zed/.config/zed/themes/
dotfiles/zed/.config/zed/settings_backup.json

# claude runtime; keep tracked config, skills, agents, hooks, scripts, and plugin inventory
dotfiles/claude/.claude/*
!dotfiles/claude/.claude/CLAUDE.md
!dotfiles/claude/.claude/mcp.json
!dotfiles/claude/.claude/keybindings.json
!dotfiles/claude/.claude/.omc-config.json
!dotfiles/claude/.claude/settings.json
!dotfiles/claude/.claude/statusline-command.sh
!dotfiles/claude/.claude/agents/
!dotfiles/claude/.claude/agents/**
!dotfiles/claude/.claude/hooks/
!dotfiles/claude/.claude/hooks/**
!dotfiles/claude/.claude/plugins/
dotfiles/claude/.claude/plugins/*
!dotfiles/claude/.claude/plugins/installed_plugins.json
!dotfiles/claude/.claude/scripts/
!dotfiles/claude/.claude/scripts/**
!dotfiles/claude/.claude/skills/
!dotfiles/claude/.claude/skills/**
