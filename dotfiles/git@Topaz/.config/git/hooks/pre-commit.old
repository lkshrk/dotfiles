#!/bin/sh
set -u

expected_email=$(git config --get user.email || printf '')
test -n "$expected_email" || {
  echo "pre-commit: missing user.email; refusing to let Git auto-detect identity" >&2
  exit 1
}

author_ident=$(git var GIT_AUTHOR_IDENT)
committer_ident=$(git var GIT_COMMITTER_IDENT)

case "$author_ident" in
  *"<$expected_email>"*) ;;
  *)
    echo "pre-commit: author identity does not match configured user.email" >&2
    echo "  expected: $expected_email" >&2
    echo "  actual:   $author_ident" >&2
    exit 1
    ;;
esac

case "$committer_ident" in
  *"<$expected_email>"*) ;;
  *)
    echo "pre-commit: committer identity does not match configured user.email" >&2
    echo "  expected: $expected_email" >&2
    echo "  actual:   $committer_ident" >&2
    exit 1
    ;;
esac

test "$(git config --bool commit.gpgsign 2>/dev/null)" = true || {
  echo "pre-commit: commit.gpgsign must be true" >&2
  exit 1
}

test "$(git config --get gpg.format 2>/dev/null)" = ssh || {
  echo "pre-commit: gpg.format must be ssh" >&2
  exit 1
}
