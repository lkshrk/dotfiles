{
  "$schema" : "https://raw.githubusercontent.com/manaflow-ai/cmux/main/web/data/cmux.schema.json",
  "schemaVersion" : 1,
  "shortcuts" : {
    "bindings" : {
      "splitDown" : ["ctrl+space", "h"],
      "splitRight" : ["ctrl+space", "v"],
      "closeTab" : ["ctrl+space", "x"],
      "equalizeSplits" : ["ctrl+space", "t"],
      "focusLeft" : "ctrl+opt+left",
      "focusRight" : "ctrl+opt+right",
      "focusUp" : "ctrl+opt+up",
      "focusDown" : "ctrl+opt+down",
      "renameWorkspace" : ["ctrl+space", "r"],
      "newTab" : ["ctrl+space", "c"],
      "closeWorkspace" : ["ctrl+space", "k"],
      "selectWorkspaceByNumber" : "opt+1",
      "prevSidebarTab" : "opt+left",
      "nextSidebarTab" : "opt+right"
    }
  }
}
