# App shortcuts
alt + ctrl + cmd - b : ~/.config/yabai/focus-app.sh 'Vivaldi'
alt + ctrl + cmd - c : ~/.config/yabai/focus-app.sh 'Chatterino'
alt + ctrl + cmd - d : ~/.config/yabai/focus-app.sh 'Discord'
alt + ctrl + cmd - e : ~/.config/yabai/focus-editor.sh
alt + ctrl + cmd + shift - e : ~/.config/yabai/focus-editor.sh --reverse
alt + ctrl + cmd - g : ~/.config/yabai/focus-gaming.sh
alt + ctrl + cmd - n : ~/.config/yabai/focus-app.sh 'Obsidian'
alt + ctrl + cmd - o : ~/.config/yabai/focus-app.sh 'OBS'
alt + ctrl + cmd - v : ~/.config/yabai/focus-app.sh 'Brave Browser'
alt + ctrl + cmd - s : ~/.config/yabai/focus-app.sh 'Signal'
alt + ctrl + cmd - t : ~/.config/yabai/focus-app.sh 'Ghostty' '\.nvim\.' '\.nvim\.' '\.nvim\.'
alt + ctrl + cmd - a : ~/.config/yabai/focus-app.sh 'ChatGPT'
alt + ctrl + cmd - return : ~/.config/yabai/finder-here.sh
alt + ctrl + cmd - 0x2C : ~/.config/yabai/focus-app.sh 'Bitwarden'

# Space shortcuts
alt + ctrl + cmd - 1 : yabai -m space --focus 1
alt + ctrl + cmd - 2 : yabai -m space --focus 2
alt + ctrl + cmd - 3 : yabai -m space --focus 3
alt + ctrl + cmd - 4 : yabai -m space --focus 4
alt + ctrl + cmd - 5 : yabai -m space --focus 5
alt + ctrl + cmd - 6 : yabai -m space --focus 6
alt + ctrl + cmd - 7 : yabai -m space --focus 7
alt + ctrl + cmd - 8 : yabai -m space --focus 8
alt + ctrl + cmd - 9 : yabai -m space --focus 9

# pseudo fullscreen for stacked apps
alt + ctrl + cmd - f : yabai -m window --grid 1:1:0:0:1:1
alt + ctrl + cmd - z : yabai -m window --toggle float

# simple halves
alt + ctrl + cmd - left  : yabai -m window --grid 1:2:0:0:1:1
alt + ctrl + cmd - right : yabai -m window --grid 1:2:1:0:1:1


# Move window
alt + ctrl + cmd + shift - left : yabai -m window --space prev && yabai -m space --focus prev
alt + ctrl + cmd + shift - right : yabai -m window --space next && yabai -m space --focus next
# move focused window to space
alt + ctrl + cmd + shift - 1 : yabai -m window --space 1 && yabai -m space --focus 1
alt + ctrl + cmd + shift - 2 : yabai -m window --space 2 && yabai -m space --focus 2
alt + ctrl + cmd + shift - 3 : yabai -m window --space 3 && yabai -m space --focus 3
alt + ctrl + cmd + shift - 4 : yabai -m window --space 4 && yabai -m space --focus 4
alt + ctrl + cmd + shift - 5 : yabai -m window --space 5 && yabai -m space --focus 5
alt + ctrl + cmd + shift - 6 : yabai -m window --space 6 && yabai -m space --focus 6

# Apply Layouts
alt + ctrl + cmd + shift - u : ~/.config/yabai/toggle-above.sh
alt + ctrl + cmd + shift - l : ~/.config/yabai/apply-layout.sh
