// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "edit_predictions": {
    "provider": "zed",
  },
  "agent_servers": {
    "mistral-vibe": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry",
    },
    "kimi": {
      "type": "registry",
    },
    "opencode": {
      "favorite_models": ["opencode/big-pickle", "opencode/minimax-m2.5-free"],
      "type": "registry",
    },
  },
  "show_edit_predictions": false,
  "agent": {
    "default_model": {
      "provider": "openrouter",
      "model": "openai/gpt-5.3-codex",
      "enable_thinking": true,
    },
    "favorite_models": [
      {
        "provider": "openrouter",
        "model": "openrouter/hunter-alpha",
        "enable_thinking": false,
      },
    ],
    "model_parameters": [],
  },
  "ssh_connections": [
    {
      "host": "hcloud",
      "projects": [
        {
          "paths": ["~/my-cluster"],
        },
      ],
    },
  ],
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "languages": {
    "C": {
      "remove_trailing_whitespace_on_save": false,
    },
    "Lua": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "stylua",
          "arguments": [
            "--syntax=Lua54",
            "--respect-ignores",
            "--stdin-filepath",
            "{buffer_path}",
            "-",
          ],
        },
      },
    },
  },
  "telemetry": {
    "metrics": false,
  },
  "terminal": {
    "font_size": 14,
  },
  "vim_mode": true,
  "ui_font_size": 14,
  "buffer_font_size": 14,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark",
  },
  "vertical_scroll_margin": 8,
  "tab_size": 2,
  "vim": {
    "use_system_clipboard": "on_yank",
  },
}
