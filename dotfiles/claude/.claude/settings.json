{
  "agent": "general-purpose",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "effortLevel": "high",
  "enabledPlugins": {
    "andrej-karpathy-skills@karpathy-skills": true,
    "better-addons@better-addons": false,
    "bubbletea-designer@human-frontier-labs-marketplace": false,
    "bubbletea-maintenance@human-frontier-labs-marketplace": false,
    "caveman@caveman": true,
    "claude-code-setup@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "codex@openai-codex": true,
    "context-mode@context-mode": true,
    "context7@claude-plugins-official": true,
    "everything-claude-code@everything-claude-code": false,
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "shadcn-dev@functional-claude": false,
    "superpowers@claude-plugins-official": false,
    "swift-lsp@claude-plugins-official": false
  },
  "env": {
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet"
  },
  "extraKnownMarketplaces": {
    "better-addons": {
      "source": {
        "repo": "FRIKKern/better-addons",
        "source": "github"
      }
    },
    "caveman": {
      "source": {
        "repo": "JuliusBrussee/caveman",
        "source": "github"
      }
    },
    "context-mode": {
      "source": {
        "repo": "mksglu/context-mode",
        "source": "github"
      }
    },
    "everything-claude-code": {
      "source": {
        "repo": "affaan-m/everything-claude-code",
        "source": "github"
      }
    },
    "functional-claude": {
      "source": {
        "repo": "nthplusio/functional-claude",
        "source": "github"
      }
    },
    "human-frontier-labs-marketplace": {
      "source": {
        "repo": "Human-Frontier-Labs-Inc/human-frontier-labs-marketplace",
        "source": "github"
      }
    },
    "karpathy-skills": {
      "source": {
        "repo": "forrestchang/andrej-karpathy-skills",
        "source": "github"
      }
    },
    "omc": {
      "source": {
        "source": "git",
        "url": "https://github.com/Yeachan-Heo/oh-my-claudecode.git"
      }
    },
    "openai-codex": {
      "source": {
        "repo": "openai/codex-plugin-cc",
        "source": "github"
      }
    }
  },
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "command": "bash '/Users/lkshrk/.claude/hooks/herdr-agent-state.sh' blocked",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "npx block-no-verify@1.1.2",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "rtk hook claude",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "bash '/Users/lkshrk/.claude/hooks/herdr-agent-state.sh' working",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "bash '/Users/lkshrk/.claude/hooks/herdr-agent-state.sh' release",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "[ -d '.wolf' ] || openwolf init 2>/dev/null || true",
            "statusMessage": "Initializing OpenWolf...",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "node -e \"const fs=require('fs'),os=require('os'),path=require('path');const base=path.join(os.homedir(),'.claude','plugins','cache','karpathy-skills');try{const orgs=fs.readdirSync(base);const org=orgs[0];const vers=fs.readdirSync(path.join(base,org));const ver=vers[0];const md=fs.readFileSync(path.join(base,org,ver,'CLAUDE.md'),'utf8');process.stdout.write('Karpathy Guidelines active:\\n'+md);}catch(e){process.stdout.write('');}\"",
            "statusMessage": "Loading Karpathy guidelines...",
            "timeout": 5,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "\"/Users/lkshrk/.claude/hooks/context-mode-cache-heal.mjs\"",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "bash '/Users/lkshrk/.claude/hooks/herdr-agent-state.sh' idle",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "bash '/Users/lkshrk/.claude/hooks/herdr-agent-state.sh' idle",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "bash '/Users/lkshrk/.claude/hooks/herdr-agent-state.sh' working",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "model": "claude-opus-4-6",
  "permissions": {
    "allow": [
      "WebSearch(*)",
      "WebFetch(*)",
      "mcp__web-search-prime__web_search_prime",
      "mcp__web-reader__webReader"
    ]
  },
  "skillOverrides": {
    "better-addons:wow-api": "user-invocable-only",
    "better-addons:wow-create": "user-invocable-only",
    "better-addons:wow-debug": "user-invocable-only",
    "better-addons:wow-init": "user-invocable-only",
    "better-addons:wow-migrate": "user-invocable-only",
    "better-addons:wow-mode": "user-invocable-only",
    "better-addons:wow-news": "user-invocable-only",
    "better-addons:wow-research": "user-invocable-only",
    "better-addons:wow-review": "user-invocable-only",
    "better-addons:wow-verify": "user-invocable-only"
  },
  "statusLine": {
    "command": "/opt/homebrew/bin/node ${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hud/omc-hud.mjs",
    "type": "command"
  },
  "theme": "dark-daltonized"
}
