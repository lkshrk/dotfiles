{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "0",
    "CLAUDE_CODE_SUBAGENT_MODEL": "claude-sonnet-5",
    "ECC_GATEGUARD": "off",
    "ECC_DISABLED_HOOKS": "stop:desktop-notify",
    "ECC_CONTEXT_MONITOR_COST_WARNINGS": "false",
    "SSH_AUTH_SOCK": "/var/folders/xn/60cxwtb13mq7_n0r4zwgy2j00000gn/T/rbw-501/ssh-agent-socket",
    "GIT_SSH_COMMAND": "ssh -o PermitLocalCommand=no"
