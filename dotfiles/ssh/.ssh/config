# Refresh the Coder workspace's file-backed Codex login before opening its
# interactive shell. It must precede `Host *`: OpenSSH takes the first value
# for LocalCommand. Kept outside Coder's generated section so `coder
# config-ssh` will not overwrite it.
Host *.coder
  LocalCommand /Users/lkshrk/Dev/dotfiles/scripts/coder-sync-codex-auth %n

Host *
  PermitLocalCommand yes
  LocalCommand test -t 1 && printf '\033]2;%n\007' || true
  ServerAliveInterval 30
  ServerAliveCountMax 3
  TCPKeepAlive yes

# ------------START-CODER-----------
# This section is managed by coder. DO NOT EDIT.
#
# You should not hand-edit this section unless you are removing it, all
# changes will be lost when running "coder config-ssh".
#
Host coder.*
	ConnectTimeout=0
	StrictHostKeyChecking=no
	UserKnownHostsFile=/dev/null
	LogLevel ERROR
	ProxyCommand /usr/local/bin/coder --global-config "/Users/lkshrk/Library/Application Support/coderv2" ssh --stdio --ssh-host-prefix coder. %h

Host *.coder
	ConnectTimeout=0
	StrictHostKeyChecking=no
	UserKnownHostsFile=/dev/null
	LogLevel ERROR

Match host *.coder !exec "/usr/local/bin/coder connect exists %h"
	ProxyCommand /usr/local/bin/coder --global-config "/Users/lkshrk/Library/Application Support/coderv2" ssh --stdio --hostname-suffix coder %h
# ------------END-CODER------------
