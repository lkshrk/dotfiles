#!/usr/bin/env bash

# Load scripting addition — space create/destroy needs it, and a Dock restart
# (login, macOS update, display reconfiguration) silently unloads it
sudo yabai --load-sa
yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"

# ── Global settings ───────────────────────────────────────────────────────────
yabai -m config layout                float
yabai -m config window_placement      second_child
yabai -m config window_shadow         float
yabai -m config window_opacity        off
yabai -m config focus_follows_mouse   off
yabai -m config mouse_follows_focus   off

# ── Mouse ─────────────────────────────────────────────────────────────────────
yabai -m config mouse_modifier        fn
yabai -m config mouse_action1         move
yabai -m config mouse_action2         resize
yabai -m config mouse_drop_action     swap

# ── Snappy UI (disable macOS space/window animations) ─────────────────────────
defaults write com.apple.dock workspaces-swoosh-animation-off -bool true
defaults write com.apple.universalaccess reduceMotion -bool true
defaults write NSGlobalDomain NSAutomaticWindowAnimationsEnabled -bool false

# ── Spaces ────────────────────────────────────────────────────────────────────
CONFIG_DIR="${HOME}/.config/yabai"

# Ensure space count and labels (3 on widescreen, 2 on portrait)
"${CONFIG_DIR}/relabel-spaces.sh" &

# ── Signals ───────────────────────────────────────────────────────────────────
# Track focus history for smart app cycling (used by focus-app.sh)
yabai -m signal --add \
  event=window_focused \
  action="${CONFIG_DIR}/track-focus.sh"

# New windows: follow sibling app space, or space 1 if first window
yabai -m signal --add \
  event=window_created \
  action="${CONFIG_DIR}/window-created.sh"

# Re-detect displays and fix space count/labels when monitors change
yabai -m signal --add \
  event=display_added \
  action="${CONFIG_DIR}/relabel-spaces.sh"
yabai -m signal --add \
  event=display_removed \
  action="${CONFIG_DIR}/relabel-spaces.sh"

echo "yabai config loaded"
