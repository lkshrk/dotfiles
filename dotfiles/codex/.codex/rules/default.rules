prefix_rule(pattern=["node", "-e", "let s=\"\";process.stdin.on(\"data\",d=>s+=d);process.stdin.on(\"end\",()=>{const j=JSON.parse(s); const data=j.data||[]; const byMetric={}; for (const x of data){const m=x.__name__; byMetric[m]??={count:0,labels:new Set(),cli:new Set(),models:new Set(),types:new Set(),token_types:new Set(),systems:new Set()}; const b=byMetric[m]; b.count++; Object.keys(x).forEach(k=>b.labels.add(k)); if(x.cli_tool)b.cli.add(x.cli_tool); if(x.model)b.models.add(x.model); if(x.type)b.types.add(x.type); if(x.token_type)b.token_types.add(x.token_type); if(x.gen_ai_system)b.systems.add(x.gen_ai_system); } for (const [m,b] of Object.entries(byMetric).sort()){ console.log(`${m}\\tseries=${b.count}\\tcli=${[...b.cli].join(\",\")||\"-\"}\\tmodels=${[...b.models].slice(0,6).join(\",\")||\"-\"}\\ttypes=${[...b.types].join(\",\")||\"-\"}\\ttoken_types=${[...b.token_types].join(\",\")||\"-\"}\\tsystems=${[...b.systems].join(\",\")||\"-\"}\\tlabels=${[...b.labels].sort().join(\",\")}`); } })"], decision="allow")
