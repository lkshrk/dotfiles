prefix_rule(pattern=["/bin/zsh", "-lc", "kubectl -n productivity exec deploy/codeberg-bridge -- node -e \"const crypto=require('crypto');const b=v=>Buffer.from(v).toString('base64url');const token=()=>{const h=b(JSON.stringify({typ:'JWT',alg:'HS256'}));const p=b(JSON.stringify({account:'1749089e-22e6-48de-af4e-165e18fbd2f9',workspace:process.env.HULY_WORKSPACE_ID,extra:{service:'ui-cleanup-audit'}}));const body=h+'.'+p;return body+'.'+crypto.createHmac('sha256',process.env.HULY_SERVER_SECRET).update(body).digest('base64url')};async function main(){const u=new URL(process.env.HULY_ENDPOINT.replace(/\\/$/,'')+'/api/v1/find-all/'+encodeURIComponent(process.env.HULY_WORKSPACE_ID));u.searchParams.set('class','workbench:class:Application');const r=await fetch(u,{headers:{Authorization:'Bearer '+token()}});const t=await r.text();if(!r.ok) throw new Error(r.status+' '+t);const j=JSON.parse(t);const arr=Array.isArray(j)?j:j.value;for (const a of arr.sort((x,y)=>(x.order??999)-(y.order??999))) console.log([a._id,a.alias,a.hidden,a.position??'',a.order??'',a.label??''].join('\\t'));}main().catch(e=>{console.error(e.message);process.exit(1)})\""], decision="allow")
