prefix_rule(pattern=["/bin/zsh", "-lc", "kubectl -n productivity exec deploy/codeberg-bridge -- node -e \"const crypto=require('crypto');const b=v=>Buffer.from(v).toString('base64url');const acct='1749089e-22e6-48de-af4e-165e18fbd2f9';const ep=process.env.HULY_ENDPOINT.replace(/\\/$/,'');const ws=process.env.HULY_WORKSPACE_ID;function tok(){const h=b(JSON.stringify({typ:'JWT',alg:'HS256'}));const p=b(JSON.stringify({account:acct,workspace:ws,extra:{service:'huly-ui-cleanup-verify'}}));const body=h+'.'+p;return body+'.'+crypto.createHmac('sha256',process.env.HULY_SERVER_SECRET).update(body).digest('base64url')}async function find(cls,q={}){const u=new URL(ep+'/api/v1/find-all/'+encodeURIComponent(ws));u.searchParams.set('class',cls);if(Object.keys(q).length)u.searchParams.set('query',JSON.stringify(q));const r=await fetch(u,{headers:{Authorization:'Bearer '+tok()}});const t=await r.text();if(!r.ok)throw new Error(r.status+' '+t);const j=JSON.parse(t);return Array.isArray(j)?j:j.value}async function main(){const apps=await find('workbench:class:Application');const hidden=await find('workbench:class:HiddenApplication',{space:'core:space:Workspace'});const hs=new Set(hidden.map(h=>h.attachedTo));const sidebar=apps.filter(a=>a.hidden===false&&!hs.has(a._id)).map(a=>a.alias).sort();console.log('sidebar_apps='+sidebar.join(','));console.log('hidden_count='+hidden.length)}main().catch(e=>{console.error(e.message);process.exit(1)})\""], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "kubectl -n productivity exec deploy/codeberg-bridge -- node -e \"const crypto=require('crypto');const b=v=>Buffer.from(v).toString('base64url');const acct='1749089e-22e6-48de-af4e-165e18fbd2f9';const ep=process.env.HULY_ENDPOINT.replace(/\\/$/,'');const ws=process.env.HULY_WORKSPACE_ID;function tok(){const h=b(JSON.stringify({typ:'JWT',alg:'HS256'}));const p=b(JSON.stringify({account:acct,workspace:ws,extra:{service:'huly-office-check'}}));const body=h+'.'+p;return body+'.'+crypto.createHmac('sha256',process.env.HULY_SERVER_SECRET).update(body).digest('base64url')}async function find(cls,q={}){const u=new URL(ep+'/api/v1/find-all/'+encodeURIComponent(ws));u.searchParams.set('class',cls);if(Object.keys(q).length)u.searchParams.set('query',JSON.stringify(q));const r=await fetch(u,{headers:{Authorization:'Bearer '+tok()}});const t=await r.text();if(!r.ok)throw new Error(r.status+' '+t);const j=JSON.parse(t);return Array.isArray(j)?j:j.value}async function main(){const apps=await find('workbench:class:Application',{alias:'love'});const hidden=await find('workbench:class:HiddenApplication',{attachedTo:'love:app:Love'});const cfg=await find('core:class:PluginConfiguration',{pluginId:'love'});console.log(JSON.stringify({app:apps[0]&&{id:apps[0]._id,alias:apps[0].alias,hidden:apps[0].hidden},hiddenCount:hidden.length,config:cfg[0]&&{id:cfg[0]._id,pluginId:cfg[0].pluginId,enabled:cfg[0].enabled,hidden:cfg[0].hidden,beta:cfg[0].beta}},null,2))}main().catch(e=>{console.error(e.message);process.exit(1)})\""], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "kubectl -n productivity exec deploy/codeberg-bridge -- node -e \"const crypto=require('crypto');const b=v=>Buffer.from(v).toString('base64url');const acct='1749089e-22e6-48de-af4e-165e18fbd2f9';const ep=process.env.HULY_ENDPOINT.replace(/\\/$/,'');const ws=process.env.HULY_WORKSPACE_ID;function tok(){const h=b(JSON.stringify({typ:'JWT',alg:'HS256'}));const p=b(JSON.stringify({account:acct,workspace:ws,extra:{service:'huly-office-disable-verify'}}));const body=h+'.'+p;return body+'.'+crypto.createHmac('sha256',process.env.HULY_SERVER_SECRET).update(body).digest('base64url')}async function find(cls,q={}){const u=new URL(ep+'/api/v1/find-all/'+encodeURIComponent(ws));u.searchParams.set('class',cls);if(Object.keys(q).length)u.searchParams.set('query',JSON.stringify(q));const r=await fetch(u,{headers:{Authorization:'Bearer '+tok()}});const t=await r.text();if(!r.ok)throw new Error(r.status+' '+t);const j=JSON.parse(t);return Array.isArray(j)?j:j.value}async function main(){const cfg=(await find('core:class:PluginConfiguration',{pluginId:'love'}))[0];const hidden=await find('workbench:class:HiddenApplication',{attachedTo:'love:app:Love'});console.log('love_enabled='+cfg.enabled);console.log('love_hidden_records='+hidden.length)}main().catch(e=>{console.error(e.message);process.exit(1)})\""], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "kubectl -n productivity exec deploy/codeberg-bridge -- node -e \"const crypto=require('crypto');const b=v=>Buffer.from(v).toString('base64url');const acct='1749089e-22e6-48de-af4e-165e18fbd2f9';const ep=process.env.HULY_ENDPOINT.replace(/\\/$/,'');const ws=process.env.HULY_WORKSPACE_ID;function tok(){const h=b(JSON.stringify({typ:'JWT',alg:'HS256'}));const p=b(JSON.stringify({account:acct,workspace:ws,extra:{service:'huly-planner-check'}}));const body=h+'.'+p;return body+'.'+crypto.createHmac('sha256',process.env.HULY_SERVER_SECRET).update(body).digest('base64url')}async function find(cls,q={}){const u=new URL(ep+'/api/v1/find-all/'+encodeURIComponent(ws));u.searchParams.set('class',cls);if(Object.keys(q).length)u.searchParams.set('query',JSON.stringify(q));const r=await fetch(u,{headers:{Authorization:'Bearer '+tok()}});const t=await r.text();if(!r.ok)throw new Error(r.status+' '+t);const j=JSON.parse(t);return Array.isArray(j)?j:j.value}async function main(){const apps=await find('workbench:class:Application');const timeApps=apps.filter(a=>a.alias==='time'||a.alias==='team').map(a=>({id:a._id,alias:a.alias,hidden:a.hidden,label:a.label}));const hidden=await find('workbench:class:HiddenApplication');const cfg=await find('core:class:PluginConfiguration',{pluginId:'time'});console.log(JSON.stringify({timeApps,hiddenTimeRecords:hidden.filter(h=>timeApps.some(a=>a.id===h.attachedTo)).length,config:cfg[0]&&{id:cfg[0]._id,pluginId:cfg[0].pluginId,enabled:cfg[0].enabled,hidden:cfg[0].hidden,beta:cfg[0].beta}},null,2))}main().catch(e=>{console.error(e.message);process.exit(1)})\""], decision="allow")
