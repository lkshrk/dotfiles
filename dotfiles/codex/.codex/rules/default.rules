prefix_rule(pattern=["node", "-e", "const fs=require(\"fs\"); const p=\"/Users/lkshrk/Dev/dotfiles/dotfiles/omni/.config/omni/settings.json\"; const cfg=JSON.parse(fs.readFileSync(p,\"utf8\")); const ensureTool=(name,spec)=>{cfg.tools[name]={...(cfg.tools[name]||{}),...spec};}; const ensureArrayItem=(arr,item)=>{if(!arr.includes(item)) arr.push(item);}; ensureArrayItem(cfg.hosts.coder,\"coder-workspace\"); const groupName=\"coder-workspace\"; let group=cfg.groups.find(g=>g.name===groupName); if(!group){group={name:groupName,description:\"Coder workspace-only development tools\",tools:[]}; const idx=cfg.groups.findIndex(g=>g.name===\"Topaz\"); if(idx>=0) cfg.groups.splice(idx,0,group); else cfg.groups.push(group);} group.description=\"Coder workspace-only development tools\"; group.tools=group.tools||[]; for(const t of [\"bun\",\"pnpm\",\"openjdk-21\",\"docker-buildx-linux\",\"docker-compose-v2\"]) ensureArrayItem(group.tools,t); ensureTool(\"bun\",{provider:\"system\"}); ensureTool(\"pnpm\",{provider:\"system\"}); ensureTool(\"openjdk-21\",{provider:\"system\",package:\"openjdk-21-jdk-headless\"}); ensureTool(\"docker-buildx-linux\",{provider:\"system\",package:\"docker-buildx\"}); ensureTool(\"docker-compose-v2\",{provider:\"system\"}); cfg.tools.docker=cfg.tools.docker||{provider:\"system\"}; cfg.tools.docker.hosts=cfg.tools.docker.hosts||{}; cfg.tools.docker.hosts.coder={provider:\"system\",package:\"docker.io\"}; fs.writeFileSync(p,JSON.stringify(cfg,null,2)+\"\\n\");"], decision="allow")
