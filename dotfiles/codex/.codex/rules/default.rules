prefix_rule(pattern=["git", "commit", "-m", "Decouple definition proposal review publishing", "-m", "Provider-neutral proposal publishing keeps Codeberg as the configured default while delaying live Forgejo API coupling until an adapter can own tokens, retries, and provider-specific merge request behavior.", "-m", "Constraint: Definition proposal pushes need a loose provider boundary so Codeberg/Forgejo can be replaced without changing controller or proposal services.", "-m", "Rejected: Coding directly against Codeberg endpoints in controller runtime | it would hardwire provider coupling before the provider adapter is stable.", "-m", "Confidence: high", "-m", "Scope-risk: narrow", "-m", "Directive: Keep provider-specific API clients behind DefinitionGitProvider and keep bot tokens inside provider construction.", "-m", "Tested: uv run pytest -q tests/test_config_validation.py tests/test_config_examples.py tests/services/test_definition_git.py; uv run ruff check src/civora/config.py src/civora/services/definition_git.py tests/test_config_validation.py tests/test_config_examples.py tests/services/test_definition_git.py; uv run mypy src tests/test_config_validation.py tests/test_config_examples.py tests/services/test_definition_git.py; uv run pytest -q; uv run mypy src tests; uv run ruff check; CIVORA_RUN_DB_TESTS=1 uv run pytest -q tests/services/test_definition_proposals_db.py tests/services/test_definition_sync_db.py; git diff --check", "-m", "Not-tested: Live Codeberg/Forgejo API calls because no bot token/provider adapter was configured for this slice. Native review subagent could not start because the agent thread limit was reached; completed local staged diff review plus full validation with no blocking findings.", "-m", "Co-authored-by: OmX <omx@oh-my-codex.dev>"], decision="allow")
prefix_rule(pattern=["git", "commit", "-m", "Generate only the Forgejo proposal client surface", "-m", "OpenAPI Generator should consume a pruned Codeberg/Forgejo Swagger document so Civora avoids committing or depending on the full forge API while the runtime stays behind DefinitionGitProvider.", "-m", "Constraint: Definition proposal automation only needs branch creation/read, file content create/update/read, and pull request list/create endpoints.", "-m", "Rejected: Generating the complete Codeberg API client | it would add noisy unused code and increase provider coupling.", "-m", "Confidence: high", "-m", "Scope-risk: narrow", "-m", "Directive: Keep generated Forgejo code in build or another reviewed generated-code area and keep application code coupled to DefinitionGitProvider.", "-m", "Tested: uv run pytest -q tests/scripts/test_prune_forgejo_openapi.py tests/test_config_examples.py tests/services/test_definition_git.py; uv run ruff check scripts/prune_forgejo_openapi.py tests/scripts/test_prune_forgejo_openapi.py README.md; uv run mypy scripts/prune_forgejo_openapi.py tests/scripts/test_prune_forgejo_openapi.py; python3 scripts/prune_forgejo_openapi.py --output build/forgejo-definition-proposals.openapi.json against live Codeberg Swagger yielded 4 paths, 7 operations, 34 definitions; uv run pytest -q; uv run mypy src tests scripts/prune_forgejo_openapi.py; uv run ruff check; CIVORA_RUN_DB_TESTS=1 uv run pytest -q tests/services/test_definition_proposals_db.py tests/services/test_definition_sync_db.py; bash -n scripts/generate-forgejo-client.sh; git diff --check", "-m", "Not-tested: Running openapi-generator-cli because this environment has no Java runtime and no openapi-generator-cli executable installed.", "-m", "Co-authored-by: OmX <omx@oh-my-codex.dev>"], decision="allow")
prefix_rule(pattern=["scripts/generate-forgejo-client.sh"], decision="allow")
prefix_rule(pattern=["git", "commit", "-m", "Run Forgejo client generation with local Java", "-m", "The Forgejo client generator now detects Homebrew OpenJDK and falls back to the npx OpenAPI Generator CLI so contributors can run the pruned generator without manually linking Java first.", "-m", "Constraint: The current macOS environment has OpenJDK installed under /opt/homebrew but /usr/libexec/java_home does not see it until linked.", "-m", "Rejected: Requiring a committed generated client in this slice | build output remains ignored and runtime coupling still belongs behind DefinitionGitProvider.", "-m", "Confidence: high", "-m", "Scope-risk: narrow", "-m", "Directive: Keep OpenAPI Generator output out of runtime imports unless a reviewed adapter wraps it behind DefinitionGitProvider.", "-m", "Tested: bash -n scripts/generate-forgejo-client.sh; uv run pytest -q tests/scripts/test_prune_forgejo_openapi.py; uv run ruff check scripts/prune_forgejo_openapi.py tests/scripts/test_prune_forgejo_openapi.py README.md; uv run mypy scripts/prune_forgejo_openapi.py tests/scripts/test_prune_forgejo_openapi.py; scripts/generate-forgejo-client.sh generated 4 paths, 7 operations, 34 definitions, and build/forgejo-client/civora_forgejo_client/api/repository_api.py; git diff --check", "-m", "Not-tested: Global Java symlink under /Library/Java/JavaVirtualMachines because the shell-local Homebrew Java path was sufficient.", "-m", "Co-authored-by: OmX <omx@oh-my-codex.dev>"], decision="allow")
