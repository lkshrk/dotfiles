            "uninstall": "rm -rf $HOME/.oh-my-zsh",
            "upgrade": "(cd $HOME/.oh-my-zsh \u0026\u0026 git pull --quiet); for p in zsh-autosuggestions zsh-syntax-highlighting; do git -C \"${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/plugins/$p\" pull --quiet; done"
