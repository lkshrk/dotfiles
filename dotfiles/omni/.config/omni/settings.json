{
  "$schema": "https://raw.githubusercontent.com/lkshrk/omni/main/spec/omni.settings.v1.schema.json",
  "version": 1,
  "groups": [
    {
      "name": "ai",
      "tools": [
        "chatgpt",
        "claude-code",
        "codex",
        "mlx",
        "opencode",
        "pi-coding-agent"
      ],
      "dots": [
        {
          "name": "claude",
          "path": "~/.claude",
          "ignore": [
            "*",
            "!/settings.json",
            "!/CLAUDE.md",
            "!/mcp.json",
            "!/plugins",
            "!/agents/",
            "!/scripts/",
            "!/.omc-config.json",
            "!/keybindings.json",
            "!/statusline-command.sh",
            "scripts"
          ]
        },
        {
          "name": "codex",
          "path": "~/.codex",
          "ignore": [
            "*",
            "!/config.toml",
            "!/mcp.json",
            "!/AGENTS.md",
            "!/RTK.md",
            "!/rules/",
            "/skills/.system/"
          ]
        },
        {
          "name": "free-claude-code",
          "path": "~/.config/free-claude-code"
        },
        {
          "name": "opencode",
          "path": "~/.config/opencode",
          "ignore": [
            "oh-my-openagent.json.backup-2026-04-13T15-21-36-926Z",
            "oh-my-openagent.json.backup-2026-04-15T16-55-25-356Z",
            "oh-my-openagent.json.backup-2026-05-01T14-49-32-879Z",
            "oh-my-openagent.json.bak.2026-04-18T12-06-45-874Z",
            "oh-my-opencode.json.clean",
            "oh-my-opencode.json.opt",
            "opencode.json.backup-2026-04-12T10-07-04-579Z",
            "opencode.json.backup-2026-04-13T15-14-05-965Z",
            "opencode.json.backup-2026-04-15T16-55-25-352Z",
            "opencode.json.backup-2026-05-01T14-49-32-875Z",
            ".gitignore"
          ]
        },
        {
          "name": "skill-lock.json",
          "path": "~/.agents/.skill-lock.json"
        }
      ]
    },
    {
      "name": "ai-plugins",
      "tools": [
        "@aisuite/chub",
        "@code-yeongyu/comment-checker",
        "ccundo",
        "claude-cmd",
        "context-mode",
        "oh-my-claude-sisyphus",
        "oh-my-codex",
        "openwolf",
        "rtk"
      ]
    },
    {
      "name": "core",
      "tools": [
        "coreutils",
        "eza",
        "fd",
        "font-hack-nerd-font",
        "font-intel-one-mono",
        "font-jetbrains-mono-nerd-font",
        "fzf",
        "jq",
        "just",
        "karakeep",
        "neovim",
        "obsidian",
        "ripgrep",
        "stow",
        "thefuck",
        "tmux",
        "tree",
        "tree-sitter",
        "tree-sitter-cli",
        "wget",
        "yq",
        "omni",
        "glow"
      ],
      "dots": [
        {
          "name": "nvim",
          "path": "~/.config/nvim",
          "ignore": [
            ".gitignore"
          ]
        },
        {
          "name": "omni",
          "path": "~/.config/omni"
        },
        {
          "name": "tmux",
          "path": "~/.config/tmux"
        },
        {
          "name": "vim",
          "path": "~/.vim"
        },
        {
          "name": "zed",
          "path": "~/.config/zed"
        },
        {
          "name": "zprofile",
          "path": "~/.zprofile"
        },
        {
          "name": "zsh",
          "path": "~/.config/zsh",
          "ignore": [
            ".zsh_history",
            ".gitignore"
          ]
        },
        {
          "name": "zshenv",
          "path": "~/.zshenv"
        },
        {
          "name": "ssh",
          "path": "~/.config/ssh"
        }
      ]
    },
    {
      "name": "desk",
      "tools": [
        "brave-browser",
        "iina",
        "zed",
        "codex-app",
        "ghostty"
      ],
      "dots": [
        {
          "name": "sleep-on-lock",
          "path": "~/Library/LaunchAgents/com.lkshrk.sleep-on-lock.plist"
        },
        {
          "name": "ghostty",
          "path": "~/.config/ghostty"
        }
      ]
    },
    {
      "name": "dev",
      "tools": [
        "gum",
        "lefthook"
