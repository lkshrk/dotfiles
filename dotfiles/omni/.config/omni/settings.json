{
  "$schema": "https://raw.githubusercontent.com/lkshrk/omni/main/spec/omni.settings.v8.schema.json",
  "version": 8,
  "groups": [
    {
      "name": "ai",
      "tools": [
        "claude-code",
        "codex",
        "opencode",
        "pi-coding-agent"
      ],
      "dots": [
        {
          "name": "claude",
          "path": "~/.claude",
          "ignore": [
            "*",
            "!/settings.json",
            "!/CLAUDE.md",
            "!/mcp.json",
            "!/plugins",
            "!/agents/",
            "!/.omc-config.json",
            "!/keybindings.json",
            "!/statusline-command.sh"
          ]
        },
        {
          "name": "codex",
          "path": "~/.codex",
          "ignore": [
            "*",
            "!/config.toml",
            "!/mcp.json",
            "!/AGENTS.md",
            "!/RTK.md",
            "/skills/.system/"
          ],
          "on_conflict": "use_repo"
        },
        {
          "name": "free-claude-code",
          "path": "~/.config/free-claude-code"
        },
        {
          "name": "opencode",
          "path": "~/.config/opencode",
          "ignore": [
            "oh-my-openagent.json.backup-2026-04-13T15-21-36-926Z",
            "oh-my-openagent.json.backup-2026-04-15T16-55-25-356Z",
            "oh-my-openagent.json.backup-2026-05-01T14-49-32-879Z",
            "oh-my-openagent.json.bak.2026-04-18T12-06-45-874Z",
            "oh-my-opencode.json.clean",
            "oh-my-opencode.json.opt",
            "opencode.json.backup-2026-04-12T10-07-04-579Z",
            "opencode.json.backup-2026-04-13T15-14-05-965Z",
            "opencode.json.backup-2026-04-15T16-55-25-352Z",
            "opencode.json.backup-2026-05-01T14-49-32-875Z",
            ".gitignore"
          ]
        },
        {
          "name": "skill-lock.json",
          "path": "~/.agents/.skill-lock.json"
        }
      ]
    },
    {
      "name": "ai-plugins",
      "tools": [
        "@aisuite/chub",
        "@code-yeongyu/comment-checker",
        "ccundo",
        "claude-cmd",
        "context-mode",
        "oh-my-claude-sisyphus",
        "oh-my-codex",
        "openwolf",
        "rtk"
