      "name": "utils",
      "tools": [
        "plantuml",
        "bcrypt",
        "better-sqlite3",
        "sshpass",
        "witr"
      ]
    },
    {
      "name": "Topaz",
      "special": "host",
      "tools": [
        "cmake",
        "docker-buildx",
        "fswatch",
        "libiscsi",
        "pkgconf",
        "parsec",
        "certifi",
        "@openai/codex",
        "numpy",
        "npm"
