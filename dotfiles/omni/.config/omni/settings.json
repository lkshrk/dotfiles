        },
        {
          "name": "moshi",
          "path": "~/.config/moshi",
          "ignored": true
        },
        {
          "name": "taskless",
          "path": "~/.config/taskless"
        },
        {
          "name": "zshrc",
          "path": "~/.zshrc",
          "hosts": {
            "Topaz": {
              "package": "zshrc@Topaz"
            }
          }
        },
        {
          "name": "talos",
          "path": "~/.config/talos",
          "ignored": true
        },
        {
          "name": "CLAUDE.md",
          "path": "~/.config/CLAUDE.md",
          "ignored": true
