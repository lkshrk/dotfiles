{
  "$schema": "https://raw.githubusercontent.com/lkshrk/omni/main/spec/omni.settings.v8.schema.json",
  "version": 8,
  "groups": [
    {
      "name": "ai",
      "tools": [
        "claude-code",
        "codex",
        "opencode",
        "pi-coding-agent"
      ],
      "dots": [
        {
          "name": "claude",
          "path": "~/.claude",
          "ignore": [
            "*",
            "!/settings.json",
            "!/CLAUDE.md",
            "!/mcp.json",
            "!/plugins",
            "!/agents/",
            "!/.omc-config.json",
            "!/keybindings.json",
            "!/statusline-command.sh"
          ]
        },
        {
          "name": "codex",
          "path": "~/.codex",
          "ignore": [
            "*",
            "!/config.toml",
            "!/mcp.json",
            "!/AGENTS.md",
            "!/RTK.md",
            "/skills/.system/"
          ],
          "on_conflict": "use_repo"
        },
        {
          "name": "free-claude-code",
          "path": "~/.config/free-claude-code"
        },
        {
          "name": "opencode",
          "path": "~/.config/opencode",
          "ignore": [
            "oh-my-openagent.json.backup-2026-04-13T15-21-36-926Z",
            "oh-my-openagent.json.backup-2026-04-15T16-55-25-356Z",
            "oh-my-openagent.json.backup-2026-05-01T14-49-32-879Z",
            "oh-my-openagent.json.bak.2026-04-18T12-06-45-874Z",
            "oh-my-opencode.json.clean",
            "oh-my-opencode.json.opt",
            "opencode.json.backup-2026-04-12T10-07-04-579Z",
            "opencode.json.backup-2026-04-13T15-14-05-965Z",
            "opencode.json.backup-2026-04-15T16-55-25-352Z",
            "opencode.json.backup-2026-05-01T14-49-32-875Z",
            ".gitignore"
          ]
        },
        {
          "name": "skill-lock.json",
          "path": "~/.agents/.skill-lock.json"
        }
      ]
    },
    {
      "name": "ai-plugins",
      "tools": [
        "ccundo",
        "claude-cmd",
        "context-mode",
        "oh-my-codex",
        "openwolf",
        "rtk"
      ]
    },
    {
      "name": "coder-workspace",
      "description": "Coder workspace base: container tooling shared by every workspace",
      "tools": [
        "docker-buildx-linux",
        "docker-compose-v2"
      ]
    },
    {
      "name": "core",
      "tools": [
        "coreutils",
        "eza",
        "fd",
        "fzf",
        "jq",
        "just",
        "neovim",
        "ripgrep",
        "stow",
        "thefuck",
        "tmux",
        "tree",
        "tree-sitter-cli",
        "wget",
        "yq",
        "omni",
        "glow",
        "zsh",
        "oh-my-zsh"
      ],
      "dots": [
        {
          "name": "nvim",
          "path": "~/.config/nvim",
          "ignore": [
            ".gitignore"
          ]
        },
        {
          "name": "omni",
          "path": "~/.config/omni",
          "ignore": [
            "settings.json.bak.20260508102147"
          ]
        },
        {
          "name": "tmux",
          "path": "~/.config/tmux"
        },
        {
          "name": "vim",
          "path": "~/.vim"
        },
        {
