{
  "$schema": "https://raw.githubusercontent.com/lkshrk/omni/main/spec/omni.settings.v17.schema.json",
  "version": 17,
  "$include": [
    "settings.d/agents.json",
    "settings.d/groups.json",
    "settings.d/tools.json"
  ],
  "settings": {
    "fallback_bin_dir": "~/.local/bin",
    "dots_git": {
      "auto_commit": true
    }
  },
  "host_settings": {
    "coder": {
      "dots_repo": "~/dotfiles",
      "dots_disabled": false,
      "dots_git": {},
      "disabled_providers": [
        "brew"
      ],
      "provider_priority": [
        "bun",
        "uv",
        "apt",
        "script",
        "npm",
        "pnpm",
        "pip"
      ]
    },
    "topaz": {
      "dots_repo": "~/Dev/dotfiles",
      "dots_disabled": false,
      "dots_git": {},
      "provider_priority": [
        "bun",
        "uv",
        "brew",
        "pnpm",
        "apt",
        "apk",
        "dnf",
        "pacman",
        "zypper",
        "npm",
        "pip"
      ]
    }
  },
  "hosts": {
    "coder": [
      "ai",
      "ai-plugins",
      "core",
      "dev",
      "dev-tooling",
      "prereqs",
      "shell",
      "test-tooling"
    ],
    "topaz": [
      "ai",
      "ai-plugins",
      "core",
      "desk",
      "dev",
      "dev-tooling",
      "gaming",
      "go",
      "infra",
      "lua",
      "mac",
      "prereqs",
      "priv",
      "python",
      "shell",
      "test-tooling",
      "ts",
      "utils"
    ]
  },
  "ignore": {
    "tools": [
      "cmake",
      "docker-buildx",
      "fswatch",
      "libiscsi",
      "pkgconf",
      "npm",
      "asyncpg"
    ]
  }
}
