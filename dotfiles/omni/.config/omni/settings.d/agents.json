{
  "agents": {
    "packages": [
      {
        "source": "mattpocock/skills"
      },
      {
        "source": "vercel-labs/skills"
      },
      {
        "source": "lkshrk/linear-ai"
      },
      {
        "source": "rjyo/moshi-skill"
      },
      {
        "source": "lkshrk/useful-skills"
      },
      {
        "source": "ShiplightAI/agent-skills-v2"
      },
      {
        "source": "ShiplightAI/agent-skills"
      },
      {
        "source": "sopaco/deepwiki-rs"
      },
      {
        "source": "JuliusBrussee/caveman"
      }
    ],
    "mcp_servers": [
      {
        "name": "litellm-tools",
        "transport": "http",
        "url": "https://api.ai.h-cloud.lan/mcp/",
        "headers": {
          "x-litellm-api-key": "${LITELLM_API}"
        },
        "agents": [
          "claude-code"
        ]
      },
      {
        "name": "shiplight",
        "transport": "stdio",
        "command": "bunx @shiplightai/mcp@latest",
        "agents": [
          "claude-code"
        ]
      },
      {
        "name": "codebase-memory-mcp",
        "transport": "stdio",
        "command": "codebase-memory-mcp",
        "agents": [
          "claude-code"
        ]
      },
      {
        "name": "context-mode",
        "transport": "stdio",
        "command": "node ./start.mjs",
        "agents": [
          "codex"
        ]
      }
    ],
    "marketplaces": [
      {
        "name": "context-mode",
        "source": "https://github.com/mksglu/context-mode.git",
        "agents": [
          "codex"
        ]
      },
      {
        "name": "lkshrk",
        "source": "https://github.com/lkshrk/agent-marketplace.git",
        "agents": [
          "codex"
        ]
      },
      {
        "name": "caveman",
        "source": "JuliusBrussee/caveman",
        "agents": [
          "claude-code"
        ]
      },
      {
        "name": "claude-plugins-official",
        "source": "anthropics/claude-plugins-official",
        "agents": [
          "claude-code"
        ]
      },
      {
        "name": "ecc",
        "source": "affaan-m/everything-claude-code",
        "agents": [
          "claude-code"
        ]
      },
      {
        "name": "ponytail",
        "source": "https://github.com/DietrichGebert/ponytail.git",
        "agents": [
          "codex"
        ]
      },
      {
        "name": "openai-codex",
        "source": "openai/codex-plugin-cc",
        "agents": [
          "claude-code"
        ]
      },
      {
        "name": "litellm",
