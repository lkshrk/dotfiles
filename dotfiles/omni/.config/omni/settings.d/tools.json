            "install": "mkdir -p \"$HOME/.local/bin\" && arch=$(uname -m) && case \"$arch\" in aarch64|arm64) arch=arm64 ;; x86_64|amd64) arch=x86_64 ;; *) exit 1 ;; esac && asset=\"glow_2.1.2_Linux_${arch}.tar.gz\" && url=\"https://github.com/charmbracelet/glow/releases/download/v2.1.2/$asset\" && tmp=$(mktemp -d) && curl -fsSL \"$url\" | tar -xz -C \"$tmp\" && found=$(find \"$tmp\" -type f -perm -111 -name glow | head -n1) && test -n \"$found\" && install -Dm755 \"$found\" \"$HOME/.local/bin/glow\"",
            "uninstall": "rm -f \"$HOME/.local/bin/glow\""
          }
        }
      ],
      "git": "https://github.com/charmbracelet/glow"
